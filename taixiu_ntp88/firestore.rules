rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hàm kiểm tra xem tài khoản đăng nhập có phải Admin không
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'toanlk04@gmail.com' ||
        request.auth.token.email == 'toanlk290804@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true
        ))
      );
    }
    
    // Bảng users: Cho phép người dùng đã đăng nhập đọc thông tin công khai (để tìm kiếm), ghi thông tin của chính mình
    match /users/{userId} {
      allow read: if true;
      // Cho phép đăng ký tài khoản mới
      allow create: if request.auth != null;
      // Cho phép chủ tài khoản hoặc Admin cập nhật toàn bộ thông tin
      // Cho phép người dùng khác cập nhật CHỈ trường balance (chuyển coin)
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance'])
      );
      allow delete: if request.auth != null && isAdmin();

      // Danh sách bạn bè (Sub-collection)
      match /friends/{friendId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId);
      }
      
      // Danh sách yêu cầu kết bạn (Sub-collection)
      match /friend_requests/{requestId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == requestId);
      }
    }

    // Cho phép đọc/ghi tin nhắn chat riêng tư giữa 2 người
    match /private_chats/{roomId} {
      allow read: if request.auth != null && (
        request.auth.uid in resource.data.get('uids', []) ||
        request.auth.uid in roomId.split('_') ||
        isAdmin()
      );
      allow write: if request.auth != null && (request.auth.uid in roomId.split('_') || isAdmin());
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (request.auth.uid in roomId.split('_') || isAdmin());
      }
    }
    
    // Chỉ cho phép người dùng đã đăng nhập xem/tạo giao dịch nạp rút của chính mình, Admin được xem tất cả
    match /transactions/{transactionId} {
      allow read: if request.auth != null && (resource != null && request.auth.uid == resource.data.userId || isAdmin());
      allow write: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Chỉ cho phép người dùng đã đăng nhập xem/tạo lịch sử đặt cược của chính mình, Admin được xem tất cả
    match /bet_history/{betId} {
      allow read: if request.auth != null && (resource != null && request.auth.uid == resource.data.userId || isAdmin());
      allow write: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Cho phép người dùng đã đăng nhập xem/gửi tin nhắn chat trong phòng game
    match /game_chat/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Bảng vinh danh vòng quay may mắn (Lucky Spin Leaderboard)
    match /lucky_spin_leaderboard/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // --- CẤU HÌNH BẢO MẬT PHỤC VỤ TRANG ADMIN ---

    // Cho phép đọc/ghi thông tin cược đang diễn ra thời gian thực
    match /active_bets/{betId} {
      allow read, write: if request.auth != null || isAdmin();
    }

    // Chỉ Admin mới được can thiệp kết quả (ghi đè), người chơi chỉ được đọc kết quả để đồng bộ
    match /game_control/{controlId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
